# =============================================================================
# Mutual Fund FAQ Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Groq API Key (required for LLM generation via Llama 3.3)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# OpenAI API Key (optional — only if using OpenAI embeddings or LLM)
# OPENAI_API_KEY=sk-your-openai-key-here
